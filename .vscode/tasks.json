{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "git: status",
            "type": "shell",
            "command": "git status",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "git: create branch",
            "type": "shell",
            "command": "git checkout -b ${input:branchName}",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "git: add all",
            "type": "shell",
            "command": "git add .",
            "group": "none",
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "git: commit",
            "type": "shell",
            "command": "git commit -m \"${input:commitMessage}\"",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "git: push",
            "type": "shell",
            "command": "git push -u origin ${input:branchName}",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "pytest: run all tests",
            "type": "shell",
            "command": "uv run pytest tests/ -v",
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "pytest: run with coverage",
            "type": "shell",
            "command": "uv run pytest tests/ -v --tb=short",
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "python: run pipeline sample",
            "type": "shell",
            "command": "uv run python araucaria_sample_pipeline.py --days-back 1",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        },
        {
            "label": "python: run integrity check",
            "type": "shell",
            "command": "uv run python -m integrity_check --base-dir output",
            "group": "none",
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "branchName",
            "type": "promptString",
            "description": "Branch name",
            "default": "main"
        },
        {
            "id": "commitMessage",
            "type": "promptString",
            "description": "Commit message"
        }
    ]
}
